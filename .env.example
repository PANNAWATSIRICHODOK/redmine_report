REDMINE_BASE_URL=http://redmine.biccorp.com
REDMINE_API_KEY=replace-with-your-api-key
REDMINE_VERIFY_SSL=true

# 16 = SD-SAP B1, 17 = SD-DEV
REDMINE_PROJECT_ID=16

# 3 = Support, 2 = Feature
REDMINE_TRACKER_ID=3

# Optional. Set to create imported commits as subtasks of an existing issue.
REDMINE_PARENT_ISSUE_ID=

# Optional. Omit REDMINE_ASSIGNED_TO_ID to assign issues to the API key owner.
REDMINE_ASSIGNED_TO_ID=

# 5 = Closed. Omit REDMINE_STATUS_ID to auto-detect status named "Closed".
REDMINE_STATUS_ID=5
REDMINE_DONE_RATIO=100

# Optional. Omit to let the program estimate from commit text.
REDMINE_ESTIMATED_HOURS=

# Optional. Omit to auto-fill less than estimated hours using AI Score.
REDMINE_SPENT_HOURS=

# 9 = Development
REDMINE_ACTIVITY_ID=9

# 14 = AI Score
REDMINE_AI_SCORE_FIELD_ID=14

# Optional. Use your own git author name or email.
GIT_AUTHOR=
REDMINE_ISSUE_PREFIX=[GIT_COMMIT]
