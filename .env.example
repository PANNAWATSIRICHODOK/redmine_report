REDMINE_BASE_URL=http://redmine.biccorp.com
REDMINE_API_KEY=replace-with-your-api-key
REDMINE_VERIFY_SSL=true

# โครงการใน Redmine: 16 = SD-SAP B1, 17 = SD-DEV
REDMINE_PROJECT_ID=16

# ประเภทงานใน Redmine: 3 = Support, 2 = Feature
REDMINE_TRACKER_ID=3

# ถ้าต้องการให้ commit ที่ import เป็นงานย่อย ให้ใส่เลข issue แม่ เช่น 4184
REDMINE_PARENT_ISSUE_ID=

# ไม่ใส่ก็ได้ ถ้าเว้นว่าง โปรแกรมจะมอบหมายงานให้เจ้าของ API key
REDMINE_ASSIGNED_TO_ID=

# สถานะ issue: 5 = Closed ถ้าเว้นว่าง โปรแกรมจะหา status ชื่อ Closed เอง
REDMINE_STATUS_ID=5
REDMINE_DONE_RATIO=100

# ไม่ใส่ก็ได้ ถ้าเว้นว่าง โปรแกรมจะประเมินเวลาจาก commit ให้อัตโนมัติ
REDMINE_ESTIMATED_HOURS=

# ไม่ใส่ก็ได้ ถ้าเว้นว่าง โปรแกรมจะกรอกเวลาที่ใช้ให้น้อยกว่าเวลาประมาณ
REDMINE_SPENT_HOURS=

# ประเภทเวลาที่ใช้: 9 = Development
REDMINE_ACTIVITY_ID=9

# custom field ของ AI Score: 14 = AI Score
REDMINE_AI_SCORE_FIELD_ID=14

# ไม่ใส่ก็ได้ ใช้กรอง commit ตามชื่อหรืออีเมลผู้เขียน commit
GIT_AUTHOR=

# prefix หน้าชื่อ issue ที่สร้างจาก commit
REDMINE_ISSUE_PREFIX=[GIT_COMMIT]
